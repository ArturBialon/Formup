  "compileOnSave": false,
  "compilerOptions": {
    "sourceMap": true,
    "esModuleInterop": true,
    "declaration": false,
    "experimentalDecorators": true,
    "importHelpers": true,
    "moduleResolution": "bundler",
    "target": "ES2022",
